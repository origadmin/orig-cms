# Database Configuration
DATA_DATABASE_DRIVER=postgres
DATA_DATABASE_SOURCE=host=127.0.0.1 user=user password=password dbname=origcms port=5432 sslmode=disable

# Server Configuration
SERVER_HTTP_ADDR=:9090

# JWT Configuration
SECURITY_JWT_SECRET=origcms-secret-key-change-in-production
SECURITY_JWT_EXPIRE_HOUR=24

# Gin Mode (read by main.go getEnv, not via runtime config)
GIN_MODE=debug
