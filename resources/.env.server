# Database Configuration
# Using new PostgreSQL database
DATABASE_TYPE=postgres
DB_SOURCE=host=127.0.0.1 user=user password=password dbname=origcms port=5432 sslmode=disable

# Server Configuration
SERVER_PORT=9090

# JWT Configuration
JWT_SECRET=origcms-secret-key-change-in-production
JWT_EXPIRE_HOUR=24

# Gin Mode
GIN_MODE=debug